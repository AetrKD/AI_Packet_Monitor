# ══════════════════════════════════════════════════════════
#  NetVisor AI  –  AI 백엔드 설정
#  이 파일을 복사해서 .env 로 저장한 뒤 원하는 섹션을 활성화하세요.
# ══════════════════════════════════════════════════════════


# ──────────────────────────────────────────────
#  ① OpenAI Cloud  (기본)
#  https://platform.openai.com/api-keys 에서 발급
# ──────────────────────────────────────────────
# OPENAI_API_KEY=sk-여기에-발급된-키를-붙여넣으세요
# OPENAI_BASE_URL 을 주석 처리하면 자동으로 OpenAI Cloud 사용


# ──────────────────────────────────────────────
#  ② LM Studio  (로컬)
#  LM Studio 실행 후 상단 "Local Server" 탭 → Start Server
#  기본 포트: 1234
# ──────────────────────────────────────────────
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL=google/gemma-3-4b
#   예) OPENAI_MODEL=lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF


# ──────────────────────────────────────────────
#  ③ Ollama  (로컬)
#  설치: https://ollama.com  →  ollama run llama3
# ──────────────────────────────────────────────
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3   ← ollama pull 로 받은 모델명


# ──────────────────────────────────────────────
#  ④ 기타 OpenAI 호환 서버 (vLLM, LocalAI 등)
# ──────────────────────────────────────────────
# OPENAI_API_KEY=your-key-or-anything
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_MODEL=your-model-name


# ──────────────────────────────────────────────
#  공통 선택 설정
# ──────────────────────────────────────────────
# 응답 최대 토큰 수 (기본값: 600)
# OPENAI_MAX_TOKENS=600

# ─── API 응답 타임아웃 (초, 기본값: 30) ──────
# 로컬 LLM 이 느리다면 늘리고, 빠르게 실패하고 싶다면 줄이세요.
OPENAI_TIMEOUT=30

# ─── Reasoning 모델 thinking 비활성화 ───────
# qwen3, deepseek-r1 등 reasoning 모델이 수천 초 동안 '생각'하는 현상 방지
# /no_think 태그를 자동으로 프롬프트 앞에 추가합니다 (기본값: true)
DISABLE_THINKING=true
